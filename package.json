{
  "name": "bot-control-hub",
  "version": "3.0.0",
  "description": "A SaaS Telegram Bot Management System with Firebase Database - Create and manage unlimited Telegram bots easily",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2": "pm2 start server.js --name bot-control-hub",
    "pm2-stop": "pm2 stop bot-control-hub",
    "pm2-restart": "pm2 restart bot-control-hub",
    "pm2-logs": "pm2 logs bot-control-hub",
    "pm2-monit": "pm2 monit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "telegram",
    "bot",
    "saas",
    "firebase",
    "telegraf",
    "nodejs",
    "telegram-bot",
    "bot-hub",
    "multi-bot"
  ],
