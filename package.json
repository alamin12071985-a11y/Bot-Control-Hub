  "repository": {
    "type": "git",
    "url": "https://github.com/lagatech/bot-control-hub"
  },
  "bugs": {
    "url": "https://github.com/lagatech/bot-control-hub/issues"
  },
  "homepage": "https://github.com/lagatech/bot-control-hub#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.1.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
